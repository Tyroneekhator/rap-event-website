<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RapNation Festival</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="theme-dark">

    <%- include("../partials/navbar") %>

    <header class="hero">
        <div class="hero-bg"></div>
        <div class="hero-overlay"></div>
        <div class="hero-glow hero-glow-left"></div>
        <div class="hero-glow hero-glow-right"></div>

        <div class="container hero-content">
            <div class="hero-badge">2026 FESTIVAL</div>

            <h1 class="hero-title">
                RAPNATION
                <span>FESTIVAL 2026</span>
            </h1>

            <div class="hero-meta">
                <div class="meta-pill">August 15–17, 2026</div>
                <div class="meta-pill">Los Angeles, CA</div>
            </div>

            <p class="hero-text">
                Experience three days of electrifying performances, rap battles,
                premium vibes, and unforgettable moments at the West Coast’s
                most exciting hip-hop festival.
            </p>

            <div class="hero-actions">
                <a href="https://www.ticketmaster.co.uk/" class="btn btn-primary">Get Tickets</a>
                <a href="/line" class="btn btn-secondary">View Lineup</a>
            </div>
        </div>
    </header>

    <main>
        <section class="section section-dark">
            <div class="container">
                <div class="section-heading">
                    <p class="section-kicker">Headliners</p>
                    <h2>Featured Artists</h2>
                    <p>
                        The names you do not want to miss.
                    </p>
                </div>

                <div class="artist-grid">
                    <article class="artist-card">
                        <img src="/images/sexydoja.jpg" alt="Featured artist">
                        <div class="artist-overlay"></div>
                        <div class="artist-info">
                            <span class="tag">Hip-Hop</span>
                            <h3>Doja Cat</h3>
                        </div>
                    </article>

                    <article class="artist-card">
                        <img src="/images/darkem.jpg" alt="Featured artist">
                        <div class="artist-overlay"></div>
                        <div class="artist-info">
                            <span class="tag">Rap</span>
                            <h3>Eminem</h3>
                        </div>
                    </article>

                    <article class="artist-card">
                        <img src="/images/kanyewest.jpg" alt="Featured artist">
                        <div class="artist-overlay"></div>
                        <div class="artist-info">
                            <span class="tag">Headliner</span>
                            <h3>Kanye West</h3>
                        </div>
                    </article>
                </div>
            </div>
        </section>

        <section class="section section-surface">
            <div class="container">
                <div class="section-heading">
                    <p class="section-kicker">Why RapNation</p>
                    <h2>Event Highlights</h2>
                    <p>
                        What makes the experience unforgettable.
                    </p>
                </div>

                <div class="highlights-grid">
                    <article class="feature-card">
                        <div class="feature-icon">20+</div>
                        <h3>Top Artists</h3>
                        <p>Big names from the rap and hip-hop scene on one stage.</p>
                    </article>

                    <article class="feature-card">
                        <div class="feature-icon">3</div>
                        <h3>Live Stages</h3>
                        <p>Multiple performance zones with nonstop energy and sound.</p>
                    </article>

                    <article class="feature-card">
                        <div class="feature-icon">VIP</div>
                        <h3>Premium Access</h3>
                        <p>Exclusive experiences, better views, and standout moments.</p>
                    </article>

                    <article class="feature-card">
                        <div class="feature-icon">50K</div>
                        <h3>Festival Crowd</h3>
                        <p>Join thousands of fans for a high-energy music weekend.</p>
                    </article>
                </div>
            </div>
        </section>

        <section class="section section-dark">
            <div class="container cta-banner">
                <div>
                    <p class="section-kicker">Ready for the vibe?</p>
                    <h2>Step Into the Biggest Rap Experience of the Year</h2>
                    <p>
                        Grab your ticket, explore the lineup, and get ready for an unforgettable weekend.
                    </p>
                </div>

                <div class="cta-actions">
                    <a href="https://www.ticketmaster.co.uk/" class="btn btn-primary">Buy Tickets</a>
                    <a href="/stages" class="btn btn-secondary">See Stages</a>
                </div>
            </div>
        </section>
    </main>

    <%- include("../partials/footer") %>

    <script src="/js/main.js"></script>
</body>
</html>