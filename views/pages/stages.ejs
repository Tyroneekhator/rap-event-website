<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RapNation Stages</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="theme-dark">

    <%- include("../partials/navbar") %>

    <header class="page-hero page-hero-stages">
        <div class="page-hero-overlay"></div>
        <div class="container page-hero-content">
            <p class="section-kicker">Festival Schedule</p>
            <h1>Stages & Experiences</h1>
            <p>
                Explore the biggest moments across the Main Stage, Battle Arena,
                Car Show Zone, and livestream experiences.
            </p>
        </div>
    </header>

    <main>
        <section class="section section-dark">
            <div class="container">
                <div class="section-heading">
                    <p class="section-kicker">Featured Event</p>
                    <h2>Surprise Main Event</h2>
                    <p>The biggest crowd moment of the weekend starts here.</p>
                </div>

                <article class="stage-feature-card">
                    <div class="stage-feature-image">
                        <img src="/images/flyod.jpg" alt="Main featured event">
                    </div>

                    <div class="stage-feature-copy">
                        <span class="tag">Special Event</span>
                        <h3>Logan Paul vs Floyd Mayweather</h3>
                        <p>
                            A high-energy surprise event experience built to bring the crowd together
                            before the main performances continue through the day.
                        </p>

                        <div class="headliner-meta">
                            <span class="meta-pill">Main Stage</span>
                            <span class="meta-pill">10:00 AM</span>
                            <span class="meta-pill">Opening Day Highlight</span>
                        </div>

                        <div class="stage-feature-actions">
                            <a href="https://www.ticketmaster.co.uk/" class="btn btn-primary">Get Tickets</a>
                            <a href="/line" class="btn btn-secondary">View Lineup</a>
                        </div>
                    </div>
                </article>
            </div>
        </section>

        <section class="section section-surface">
            <div class="container">
                <div class="section-heading">
                    <p class="section-kicker">Festival Zones</p>
                    <h2>Where the Energy Lives</h2>
                    <p>Move through the festival and find your perfect experience.</p>
                </div>

                <div class="stages-grid">
                    <article class="stage-card">
                        <div class="stage-card-image">
                            <img src="/images/rapbat.jpg" alt="Rap battle stage">
                        </div>
                        <div class="stage-card-body">
                            <span class="tag">12:00 PM</span>
                            <h3>Battle Arena</h3>
                            <p>
                                Watch top rappers go head-to-head in a live showdown packed with lyrics,
                                energy, and crowd reactions.
                            </p>
                        </div>
                    </article>

                    <article class="stage-card">
                        <div class="stage-card-image">
                            <img src="/images/carss.jpg" alt="Car show zone">
                        </div>
                        <div class="stage-card-body">
                            <span class="tag">2:00 PM</span>
                            <h3>Car Show Zone</h3>
                            <p>
                                See custom cars, standout visuals, and festival culture brought together
                                in one premium showcase.
                            </p>
                        </div>
                    </article>

                    <article class="stage-card">
                        <div class="stage-card-image">
                            <img src="/images/eminem.jpg" alt="Main stage">
                        </div>
                        <div class="stage-card-body">
                            <span class="tag">6:00 PM</span>
                            <h3>Main Stage</h3>
                            <p>
                                The biggest performances, headline sets, and unforgettable moments happen here
                                as the night builds.
                            </p>
                        </div>
                    </article>

                    <article class="stage-card">
                        <div class="stage-card-image">
                            <img src="/images/advice.jpg" alt="Livestream zone">
                        </div>
                        <div class="stage-card-body">
                            <span class="tag">All Day</span>
                            <h3>Livestream Zone</h3>
                            <p>
                                Can’t make it in person? Catch select moments, updates, and digital access
                                through the livestream experience.
                            </p>
                        </div>
                    </article>
                </div>
            </div>
        </section>

        <section class="section section-dark">
            <div class="container">
                <div class="section-heading">
                    <p class="section-kicker">Daily Schedule</p>
                    <h2>Festival Timeline</h2>
                    <p>Plan your day and catch every major moment.</p>
                </div>

                <div class="schedule-list">
                    <article class="schedule-item">
                        <div class="schedule-time">10:00 AM</div>
                        <div class="schedule-content">
                            <h3>Special Main Event</h3>
                            <p>Main Stage · Surprise crowd experience</p>
                        </div>
                    </article>

                    <article class="schedule-item">
                        <div class="schedule-time">12:00 PM</div>
                        <div class="schedule-content">
                            <h3>Rap Battle Showcase</h3>
                            <p>Battle Arena · Competitive live performance</p>
                        </div>
                    </article>

                    <article class="schedule-item">
                        <div class="schedule-time">2:00 PM</div>
                        <div class="schedule-content">
                            <h3>Car Culture Showcase</h3>
                            <p>Car Show Zone · Premium auto and lifestyle display</p>
                        </div>
                    </article>

                    <article class="schedule-item">
                        <div class="schedule-time">6:00 PM</div>
                        <div class="schedule-content">
                            <h3>Evening Main Stage Set</h3>
                            <p>Main Stage · Major performances and headline energy</p>
                        </div>
                    </article>

                    <article class="schedule-item">
                        <div class="schedule-time">9:30 PM</div>
                        <div class="schedule-content">
                            <h3>Headliner Performance</h3>
                            <p>Main Stage · Prime-time festival finale</p>
                        </div>
                    </article>
                </div>
            </div>
        </section>

        <section class="section section-surface">
            <div class="container cta-banner">
                <div>
                    <p class="section-kicker">Keep Exploring</p>
                    <h2>Find the Artists Behind the Biggest Moments</h2>
                    <p>Check the lineup and discover who is performing across the festival weekend.</p>
                </div>

                <div class="cta-actions">
                    <a href="/line" class="btn btn-primary">View Lineup</a>
                    <a href="/contact" class="btn btn-secondary">Contact Us</a>
                </div>
            </div>
        </section>
    </main>

    <%- include("../partials/footer") %>

</body>
</html>